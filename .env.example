# Echo — environment variable template
# Copy to .env and fill in your values.

# Filecoin FEVM RPC endpoint
# Calibration testnet: https://api.calibration.node.glif.io/rpc/v1
# Mainnet:             https://api.node.glif.io/rpc/v1
RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Deployed EchoMemoryRegistryV3 proxy address
# Calibration testnet (deployed 2026-06-21): 0x962C42f208d89D5bF1698E3397BC78176D70cE0c
CONTRACT_ADDRESS=0x962C42f208d89D5bF1698E3397BC78176D70cE0c

# Wallet private key for signing transactions (NEVER use a mainnet key here)
PRIVATE_KEY=0x_your_private_key_here

# Synapse SDK private key — wallet must be funded with FIL (gas) + USDFC (storage)
# Get testnet tFIL from https://faucet.calibnet.chainsafe-fil.io
# Get testnet tUSDFC from the USDFC faucet (see https://docs.filecoin.cloud)
SYNAPSE_PRIVATE_KEY=0x_your_synapse_private_key_here

# Synapse chain: 'mainnet' or 'calibration' (default: calibration)
SYNAPSE_CHAIN=calibration

# AES-256-GCM encryption key (hex-encoded 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Omit to auto-generate on startup (non-persistent)
ENCRYPTION_KEY=

# REST API port (default: 3000)
PORT=3000

# Keeper settings — only needed when running keeper.js
# KEEPER_PRIVATE_KEY: keeper's own wallet key (enables on-chain deductions)
# KEEPER_FEE_WEI: fee per successful re-pin in wei (default: 0.01 FIL)
KEEPER_PRIVATE_KEY=
KEEPER_FEE_WEI=10000000000000000
KEEPER_INTERVAL_MS=3600000
KEEPER_FROM_BLOCK=0
